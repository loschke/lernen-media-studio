# ─── KI-Provider ──────────────────────────────────────────────────────────
# Wird vom @ai-sdk/google Package automatisch gelesen.
GOOGLE_GENERATIVE_AI_API_KEY=

# Wird vom @ai-sdk/anthropic Package automatisch gelesen (für Chat).
ANTHROPIC_API_KEY=

# ─── Auth (OIDC via loschke-auth) ─────────────────────────────────────────
# Issuer + explizite Endpoints. Better-Auth ist unter /api/auth/* gemountet,
# kein root-/.well-known/-Handler vorhanden — daher kein Auto-Discovery.
OIDC_ISSUER=https://auth.loschke.ai/api/auth
OIDC_AUTHORIZE_URL=https://auth.loschke.ai/api/auth/oauth2/authorize
OIDC_TOKEN_URL=https://auth.loschke.ai/api/auth/oauth2/token
OIDC_USERINFO_URL=https://auth.loschke.ai/api/auth/oauth2/userinfo
OIDC_END_SESSION_URL=https://auth.loschke.ai/api/auth/oauth2/end-session
# JWKS direkt — Discovery-Doc liefert 404 in der aktuellen loschke-auth-Version,
# also setzen wir den jwks_uri explizit statt ihn aus dem Discovery-Doc zu lösen.
OIDC_JWKS_URL=https://auth.loschke.ai/api/auth/jwks
OIDC_CLIENT_ID=lernen-media-studio
OIDC_CLIENT_SECRET=
# In Prod auf Live-Callback-URL umstellen.
OIDC_REDIRECT_URI=http://localhost:3001/api/auth/callback

# Multi-Instanz-Gate: Login schlaegt fehl, wenn der User in loschke-auth
# keine approved Membership in der zur App gehoerenden Organization hat.
# Default: OIDC_CLIENT_ID — Konvention ist eine Org pro App, deren Slug
# dem Client-ID entspricht. Nur setzen, wenn Slug abweicht.
# AUTH_REQUIRED_ORG_SLUG=

# ─── User-DB (Neon, separat von loschke-auth) ─────────────────────────────
# Eigene Neon-DB für users + credits. PRD § NG8 verbietet Billing/Credits in loschke-auth.
DATABASE_URL=

# ─── Credits ──────────────────────────────────────────────────────────────
# Initial-Saldo pro neu provisioniertem User.
DEFAULT_CREDITS=250

# ─── Bildgenerierung ──────────────────────────────────────────────────────
# Erlaubt: 1K, 2K, 4K. Default: 1K. Größere Werte können das Vercel
# Response-Body-Limit (4.5 MB) sprengen.
DEFAULT_IMAGE_SIZE=1K

# ─── Cloudflare R2 (Galerie-Storage) ──────────────────────────────────────
# R2 Account ID — zu finden im Cloudflare Dashboard rechts in der Sidebar.
R2_ACCOUNT_ID=
# R2 API Token (S3-kompatibel): Cloudflare → R2 → Manage R2 API Tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Bucket-Name (vorher manuell anlegen).
R2_BUCKET_NAME=
